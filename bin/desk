#!/usr/bin/env bash

set -e

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$ROOT_DIR/scripts/config.sh"

case "${1:-help}" in
    ssh)
        exec "$ROOT_DIR/scripts/login.sh"
        ;;
    doctor)
        exec "$ROOT_DIR/scripts/doctor.sh"
        ;;
    deploy)
        shift
        exec "$ROOT_DIR/scripts/deploy.sh" "$@"
        ;;
    logs)
        exec "$ROOT_DIR/scripts/logs.sh"
        ;;
    cache)
        exec "$ROOT_DIR/scripts/cache.sh"
        ;;
    rollback)
        exec "$ROOT_DIR/scripts/rollback.sh"
        ;;
    *)
        cat <<MENU
Radium Desk Toolkit

Usage:
  desk ssh
  desk deploy "Commit message"
  desk doctor
  desk logs
  desk cache
  desk rollback
MENU
        ;;
esac
