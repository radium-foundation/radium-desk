APP_NAME="Radium Desk"
APP_VERSION=4.0.0
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=Asia/Kolkata

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

DASHBOARD_LIVE_MODE=auto
DASHBOARD_POLL_INTERVAL_MS=30000
TEAM_MEMBER_ACTIVITY_THROTTLE_SECONDS=60

# Hybrid Realtime (Reverb) — optional hard kill-switches.
# Runtime enablement is controlled in Admin → System Settings → Hybrid Realtime.
# When an env key is explicitly false, that feature stays off regardless of admin toggle.
# REVERB_REF_NO_ENABLED=
# REVERB_ASSIGNMENT_ENABLED=
# REVERB_CASE_STATUS_ENABLED=
# REVERB_INCOMING_CALL_ENABLED=
# REVERB_DESKTOP_NOTIFICATION_ENABLED=
# REVERB_OPERATOR_ALERT_ENABLED=

# Operator Alert System (Phase 0 foundation). Keep disabled until Phase 1+.
OPERATOR_ALERTS_ENABLED=false
OPERATOR_ALERTS_DESKTOP_ENABLED=true
OPERATOR_ALERTS_SOUND_ENABLED=true

# When true, dashboard global search is visually primary and New Service Request is secondary.
UNIFIED_INTAKE_PRIMARY=false

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
# Enable cron-driven queue worker on shared hosting (Hostinger). Leave false for local `composer dev`.
QUEUE_CRON_WORKER_ENABLED=false
# Capture queue + integration health snapshots on a schedule.
INFRASTRUCTURE_METRICS_ENABLED=false
# Database queue: seconds before a reserved job is released back to the queue.
# DB_QUEUE_RETRY_AFTER=90

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_ENABLED=true
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Customer-facing support contact shown in notification emails.
COMMUNICATION_ACTION_SUPPORT_EMAIL=support@radiumbox.com
COMMUNICATION_ACTION_SUPPORT_PHONE="+91 XXXXX XXXXX"
# COMMUNICATION_ACTION_SUPPORT_WHATSAPP=
# COMMUNICATION_ACTION_SUPPORT_WEBSITE=
# Deprecated legacy fallback when structured fields are empty.
COMMUNICATION_ACTION_SUPPORT_CONTACT=support@radiumbox.com

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Enable Cashfree webhook HMAC verification in production only when the secret is set.
# When CASHFREE_VERIFY_SIGNATURE=true, CASHFREE_CLIENT_SECRET must be configured.
# Keep verification false for local development and CI without Cashfree credentials.
CASHFREE_VERIFY_SIGNATURE=false
# Cashfree dashboard client secret. Required when CASHFREE_VERIFY_SIGNATURE=true.
CASHFREE_CLIENT_SECRET=
CASHFREE_SYSTEM_USER_EMAIL=superadmin@radium.local

SMART_ASSIGNMENT_ENABLED=true
SMART_ASSIGNMENT_DEFERRED_ENABLED=true
SMART_ASSIGNMENT_DEFERRED_BATCH_SIZE=5
SMART_ASSIGNMENT_DEFERRED_SCHEDULE_INTERVAL_MINUTES=5

IRA_ASSIGNMENT_TELEGRAM_BATCH_ENABLED=true
IRA_ASSIGNMENT_TELEGRAM_BATCH_DELAY_MINUTES=5

INTERAKT_API_KEY=
INTERAKT_WEBHOOK_SECRET=
INTERAKT_BASE_URL=https://api.interakt.ai
INTERAKT_VERIFY_SIGNATURE=false
INTERAKT_FLOW_ID=

BONVOICE_VERIFY_WEBHOOK_AUTH=false
BONVOICE_REQUIRE_BEARER=false
# Deprecated: prefer BONVOICE_VERIFY_WEBHOOK_AUTH and BONVOICE_REQUIRE_BEARER.
BONVOICE_VERIFY_SIGNATURE=false
BONVOICE_WEBHOOK_TOKEN=
BONVOICE_ACCOUNT_ID=
BONVOICE_MISSED_CALL_RECOVERY_ENABLED=false
BONVOICE_AUTO_OPEN_CUSTOMER360=false
BONVOICE_CLICK_TO_CALL_ENABLED=false
BONVOICE_API_BASE_URL=https://backend.pbx.bonvoice.com
BONVOICE_API_USERNAME=
BONVOICE_API_PASSWORD=
BONVOICE_DID=8040837125

INTERAKT_FLOW_TOKEN_TTL_HOURS=24
INTERAKT_TEMPLATE_REQUEST_SERIAL=support_schedule
INTERAKT_TEMPLATE_REQUEST_SERIAL_ENABLED=true
INTERAKT_TEMPLATE_REQUEST_SERIAL_LANGUAGE=en
INTERAKT_TEMPLATE_REQUEST_SERIAL_DISPLAY="Order Update"
INTERAKT_TEMPLATE_SUPPORT_APPOINTMENT_BOOKED=
INTERAKT_TEMPLATE_SUPPORT_APPOINTMENT_BOOKED_ENABLED=false
INTERAKT_TEMPLATE_SUPPORT_APPOINTMENT_BOOKED_LANGUAGE=en
INTERAKT_TEMPLATE_SUPPORT_APPOINTMENT_BOOKED_DISPLAY="Support Appointment Booked"
INTERAKT_TEMPLATE_CUSTOMER_WAITING_FOLLOWUP=support_schedule_followup
INTERAKT_TEMPLATE_CUSTOMER_WAITING_FOLLOWUP_ENABLED=true
INTERAKT_TEMPLATE_CUSTOMER_WAITING_FOLLOWUP_LANGUAGE=en
INTERAKT_TEMPLATE_CUSTOMER_WAITING_FOLLOWUP_DISPLAY="Support Reminder"
INTERAKT_TEMPLATE_CALLBACK_SCHEDULE=callback_schedule
INTERAKT_TEMPLATE_CALLBACK_SCHEDULE_ENABLED=true
INTERAKT_TEMPLATE_CALLBACK_SCHEDULE_LANGUAGE=en
INTERAKT_TEMPLATE_CALLBACK_SCHEDULE_DISPLAY="Callback Schedule"
# Optional lifecycle templates — set *_ENABLED=true when activating in Interakt
# INTERAKT_TEMPLATE_REPAIR_STARTED=
# INTERAKT_TEMPLATE_REPAIR_STARTED_ENABLED=false

RADIUMBOX_ENABLED=true
RADIUMBOX_BASE_URL=https://admin.radiumbox.com
RADIUMBOX_TIMEOUT_SECONDS=5
RADIUMBOX_CONNECT_TIMEOUT_SECONDS=3

# Incoming Email Intake + Gmail live sync (no historical import).
INBOUND_EMAIL_ENABLED=false
INBOUND_EMAIL_GMAIL_ENABLED=false
# Path to Google service account JSON (domain-wide delegation) OR inline JSON.
GOOGLE_SERVICE_ACCOUNT_JSON=
# Optional default impersonation user; sync impersonates each mailbox address.
GOOGLE_WORKSPACE_IMPERSONATED_USER=
# Comma-separated mailboxes to sync (defaults to inbound_email.mailboxes keys).
INBOUND_EMAIL_GMAIL_MAILBOXES=support@radiumbox.com
INBOUND_EMAIL_GMAIL_SYNC_INTERVAL_MINUTES=1

AI_PROVIDER=null

TELEGRAM_BOT_TOKEN=
IRA_DAILY_BRIEFING_TIME=08:00
IRA_NOTIFICATION_COOLDOWN_MINUTES=60
